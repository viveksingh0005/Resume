# 🔐 Dependencies
node_modules/

# 🔐 Environment variables (VERY IMPORTANT)
.env
*.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# 🔐 Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# 🔐 Runtime data
pids
*.pid
*.seed
*.pid.lock

# 🔐 Coverage directory (for testing)
coverage/

# 🔐 Build files
dist/
build/

# 🔐 OS files
.DS_Store
Thumbs.db

# 🔐 Editor files
.vscode/
.idea/

# 🔐 Temporary files
tmp/
temp/

# 🔐 Cache
.cache/

# 🔐 Optional: ignore uploads (if you store files)
uploads/

# 🔐 Optional: ignore database files (if using local DB like SQLite)
*.sqlite
*.sqlite3
*.db

# 🔐 Optional: ignore package-lock (only if you want, usually keep it)
# package-lock.json

# 🔐 Optional: ignore secrets/configs
config/*.json